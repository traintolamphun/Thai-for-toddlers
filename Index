<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Thai Nightly Practice</title>
    <style>
        body { margin: 0; font-family: 'Comic Sans MS', cursive, sans-serif; background: #0f172a; display: flex; flex-direction: column; align-items: center; height: 100vh; overflow: hidden; color: white; touch-action: manipulation; }
        
        /* Timer Bar Container */
        #timer-container { width: 100%; height: 15px; background: #334155; position: fixed; top: 0; }
        #timer-bar { width: 100%; height: 100%; background: linear-gradient(to right, #4ade80, #facc15, #f87171); transition: width 1s linear; }

        #card { width: 85%; height: 70%; background: #ffffff; border-radius: 40px; box-shadow: 0 0 40px rgba(77, 124, 254, 0.4); display: flex; flex-direction: column; justify-content: space-around; align-items: center; cursor: pointer; border: 8px solid #FFD700; margin-top: 40px; overflow: hidden; padding: 20px; box-sizing: border-box; }
        
        #gif-container { width: 100%; height: 50%; display: flex; justify-content: center; align-items: center; }
        #gif { max-width: 100%; max-height: 100%; border-radius: 20px; object-fit: contain; }
        
        #thai-word { font-size: 60px; color: #1e293b; font-weight: 900; margin-top: 10px; text-align: center; }
        #phonetic { font-size: 22px; color: #64748b; margin-top: -10px; }

        /* End Screen Overlay */
        #end-screen { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: #0f172a; display: none; flex-direction: column; justify-content: center; align-items: center; z-index: 100; }
        #end-screen h1 { font-size: 50px; color: #FFD700; }
        #end-screen p { font-size: 24px; }
    </style>
</head>
<body>

    <div id="timer-container"><div id="timer-bar"></div></div>

    <div id="card" onclick="playAndNext()">
        <div id="gif-container">
            <img id="gif" src="https://media.giphy.com/media/v1.Y2lkPTc5MGI3NjExMzM5amR4ZGZ4YmZ6Z3R6bmZzZ3F6c2Z6eGZ6eGZ6eGZ6eGZ6eCZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9Zw/v8857rM5N1Zsc/giphy.gif">
        </div>
        <div id="thai-word">ช้าง</div>
        <div id="phonetic">Chaang (Elephant)</div>
    </div>

    <div id="end-screen">
        <div style="font-size: 100px;">😴</div>
        <h1>ฝันดี</h1>
        <p>Fan-Dee (Sweet Dreams)</p>
        <p style="font-size: 16px; opacity: 0.6;">Time for bed!</p>
    </div>

    <script>
        const cards = [
            { gif: "https://media.giphy.com/media/v1.Y2lkPTc5MGI3NjExMzM5amR4ZGZ4YmZ6Z3R6bmZzZ3F6c2Z6eGZ6eGZ6eGZ6eGZ6eCZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9Zw/v8857rM5N1Zsc/giphy.gif", thai: "ช้าง", eng: "Chaang (Elephant)" },
            { gif: "https://media.giphy.com/media/v1.Y2lkPTc5MGI3NjExNXN6ZzR6Z3R6bmZzZ3F6c2Z6eGZ6eGZ6eGZ6eGZ6eCZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9Zw/ICOgUNoHOvGtu/giphy.gif", thai: "แมว", eng: "Maew (Cat)" },
            { gif: "https://media.giphy.com/media/v1.Y2lkPTc5MGI3NjExNXN6ZzR6Z3R6bmZzZ3F6c2Z6eGZ6eGZ6eGZ6eGZ6eCZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9Zw/q7776f8e754zC/giphy.gif", thai: "นก", eng: "Nok (Bird)" },
            { gif: "https://media.giphy.com/media/v1.Y2lkPTc5MGI3NjExNHB9amR4ZGZ4YmZ6Z3R6bmZzZ3F6c2Z6eGZ6eGZ6eGZ6eGZ6eCZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9Zw/Z9WQLSrsQKH3G/giphy.gif", thai: "ปลา", eng: "Plah (Fish)" },
            { gif: "https://media.giphy.com/media/v1.Y2lkPTc5MGI3NjExNGR6ZzR6Z3R6bmZzZ3F6c2Z6eGZ6eGZ6eGZ6eGZ6eCZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9Zw/kFfS62SsuK800/giphy.gif", thai: "อาบน้ำ", eng: "Arp-Nam (Bath)" }
        ];

        let currentIndex = 0;
        let timeLeft = 300; // 5 minutes in seconds
        const totalTime = 300;

        // Timer Logic
        const timerInterval = setInterval(() => {
            timeLeft--;
            const percentage = (timeLeft / totalTime) * 100;
            document.getElementById('timer-bar').style.width = percentage + "%";

            if (timeLeft <= 0) {
                clearInterval(timerInterval);
                showEndScreen();
            }
        }, 1000);

        function speak(text) {
            window.speechSynthesis.cancel();
            const utterance = new SpeechSynthesisUtterance(text);
            utterance.lang = 'th-TH';
            utterance.rate = 0.7;
            window.speechSynthesis.speak(utterance);
        }

        function playAndNext() {
            speak(cards[currentIndex].thai);
            setTimeout(() => {
                currentIndex = (currentIndex + 1) % cards.length;
                updateUI();
            }, 1500);
        }

        function updateUI() {
            const card = cards[currentIndex];
            document.getElementById('gif').src = card.gif;
            document.getElementById('thai-word').innerText = card.thai;
            document.getElementById('phonetic').innerText = card.eng;
        }

        function showEndScreen() {
            speak("ฝันดี"); // Say Goodnight
            document.getElementById('end-screen').style.display = 'flex';
        }
    </script>
</body>
</html>
